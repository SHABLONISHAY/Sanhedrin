---
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const norm = (p: string) => p.endsWith('/') && p.length > 1 ? p.slice(0, -1) : p;
const currentPath = norm(Astro.url.pathname);
const isActive = (href: string) => norm(href) === currentPath;

// These overflow into "עוד" on smaller screens, appear as direct links on larger ones.
// primaryClass: Tailwind classes for the <li> in the primary nav
// moreClass: Tailwind classes for the <li> in the dropdown (opposite — shown only when hidden from primary)
const overflow = [
  { href: `${base}relevance`, label: 'רלוונטיות להיום', primaryClass: 'hidden sm:block', moreClass: 'sm:hidden' },
  { href: `${base}rulings`,   label: 'פסיקות',           primaryClass: 'hidden md:block', moreClass: 'md:hidden' },
  { href: `${base}articles`,  label: 'מאמרים ותומכים',  primaryClass: 'hidden lg:block', moreClass: 'lg:hidden' },
];

// Always inside the dropdown
const alwaysMore = [
  { href: `${base}faq`,           label: 'שאלות נפוצות' },
  { href: `${base}sanhedrin`,     label: 'הסנהדרין ומשמעה' },
  { href: `${base}smicha`,        label: 'חידוש הסמיכה' },
  { href: `${base}small-bet-din`, label: 'ב"ד קטנה בכל עיר' },
  { href: `${base}tzochek`,       label: 'צוחק מי שצוחק אחרון' },
  { href: `${base}parshiot`,      label: 'פרשות השבוע' },
  { href: `${base}about`,         label: 'אודות' },
];

const moreActive = [...overflow, ...alwaysMore].some(l => isActive(l.href));

const linkClass = (href: string) =>
  `px-3 py-2 rounded text-sm font-medium transition-colors whitespace-nowrap ${
    isActive(href)
      ? 'text-[#003f87] bg-[#e8f0fb] font-semibold'
      : 'text-gray-700 hover:bg-[#f0f4ff] hover:text-[#003f87]'
  }`;

const menuItemClass = (href: string) =>
  `block px-4 py-2 text-sm whitespace-nowrap transition-colors ${
    isActive(href)
      ? 'text-[#003f87] bg-[#e8f0fb] font-semibold'
      : 'text-gray-700 hover:bg-[#f0f4ff] hover:text-[#003f87]'
  }`;
---

<header class="bg-white shadow-sm border-t-4 border-t-[#003f87] sticky top-0 z-50">
  <nav class="max-w-7xl mx-auto px-4 flex items-center justify-between h-14">
    <a href={base} class="shrink-0 flex items-center">
      <img
        src={`${base}images/a9aaac00894460c500a267eba47c2d1b.jpg`}
        alt="סנהדרין לישראל"
        class="h-9 w-auto"
      />
    </a>

    <ul class="flex items-center gap-0.5 list-none m-0 p-0">

      <!-- ראשי — always visible -->
      <li class="shrink-0">
        <a href={base} class={linkClass(base)}>ראשי</a>
      </li>

      <!-- Overflow links — visible as direct links from sm/md/lg and up -->
      {overflow.map(link => (
        <li class={`shrink-0 ${link.primaryClass}`}>
          <a href={link.href} class={linkClass(link.href)}>{link.label}</a>
        </li>
      ))}

      <!-- "עוד" dropdown -->
      <li class="shrink-0 relative" id="more-nav">
        <button
          id="more-btn"
          aria-haspopup="true"
          aria-expanded="false"
          class={`flex items-center gap-1 px-3 py-2 rounded text-sm font-medium transition-colors whitespace-nowrap
            ${moreActive
              ? 'text-[#003f87] bg-[#e8f0fb] font-semibold'
              : 'text-gray-700 hover:bg-[#f0f4ff] hover:text-[#003f87]'
            }`}
        >
          עוד
          <svg id="more-chevron" class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <ul
          id="more-menu"
          class="hidden absolute left-0 top-full mt-1 bg-white border border-[#dde3ed] rounded-lg shadow-lg min-w-max py-1 z-50 list-none p-0 m-0"
          role="menu"
        >
          <!-- Overflow links shown here only when they're hidden from the primary nav -->
          {overflow.map(link => (
            <li role="none" class={link.moreClass}>
              <a href={link.href} role="menuitem" class={menuItemClass(link.href)}>{link.label}</a>
            </li>
          ))}

          <!-- Divider shown only when overflow items are present (mobile/sm/md) -->
          <li class="lg:hidden" role="none" aria-hidden="true">
            <hr class="my-1 border-[#dde3ed]" />
          </li>

          <!-- Always-in-dropdown links -->
          {alwaysMore.map(link => (
            <li role="none">
              <a href={link.href} role="menuitem" class={menuItemClass(link.href)}>{link.label}</a>
            </li>
          ))}
        </ul>
      </li>

      <!-- צור קשר — always last -->
      <li class="shrink-0">
        <a href={`${base}contact`} class={linkClass(`${base}contact`)}>צור קשר</a>
      </li>

    </ul>
  </nav>
</header>

<script>
  const btn = document.getElementById('more-btn');
  const menu = document.getElementById('more-menu');
  const chevron = document.getElementById('more-chevron');

  function open() {
    menu!.classList.remove('hidden');
    btn!.setAttribute('aria-expanded', 'true');
    chevron!.style.transform = 'rotate(180deg)';
  }
  function close() {
    menu!.classList.add('hidden');
    btn!.setAttribute('aria-expanded', 'false');
    chevron!.style.transform = '';
  }

  btn!.addEventListener('click', (e) => {
    e.stopPropagation();
    menu!.classList.contains('hidden') ? open() : close();
  });

  document.addEventListener('click', close);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') close(); });
</script>
