];
---

<Layout title="חשיבות הסנהדרין על פרשות השבוע">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#003f87] mb-2">חשיבות הסנהדרין על סדר פרשות השבוע</h1>
    <div class="w-16 h-1 bg-[#003f87] mb-4"></div>
    <p class="text-gray-600 mb-8">ממתק שבועי לפרשת השבוע — חיבור בין הפרשה לרעיון חידוש הסנהדרין</p>

    <div class="space-y-8">
      {portions.map(section => (
        <div>
          <h2 class="text-xl font-bold text-[#003f87] mb-4 bg-[#e8f0fb] px-4 py-2 rounded-lg inline-block">{section.book}</h2>
          <div class="grid gap-4">
            {section.items.map(item => (
              <div class="bg-white rounded-lg border border-[#dde3ed] p-5 shadow-sm">
                <h3 class="font-bold text-[#003f87] mb-2">🍭 ממתק לפרשת {item.name}</h3>
                <p class="text-gray-700 text-sm leading-relaxed">{item.summary}</p>
                <p class="text-[#003f87] text-sm font-medium mt-2">רק סנהדרין תאחד את ההלכה ואת העם!</p>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 bg-[#e8f0fb] rounded-lg border border-[#c5d5f0] p-6">
      <p class="text-[#003f87] font-semibold mb-1">לקבלת ממתקים שבועיים עדכניים</p>
      <p class="text-gray-700 text-sm">הצטרפו לקבוצת הד"ת שלנו ותקבלו ממתק לפרשת השבוע מדי שישי</p>
      <a href="/contact" class="inline-block mt-3 bg-[#003f87] text-white font-medium px-6 py-2 rounded hover:bg-[#0057b8] transition-colors text-sm">
        הצטרפו לקבוצה
      </a>
    </div>
  </div>
</Layout>
