---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="ראשי">
  <!-- Hero with collage -->
  <section class="bg-[#003f87] text-white py-10">
    <div class="max-w-5xl mx-auto px-6 flex flex-col md:flex-row items-center gap-8">
      <div class="flex-1 text-center md:text-right">
        <h1 class="text-4xl font-bold mb-4">סנהדרין לישראל!</h1>
        <p class="text-blue-200 text-lg max-w-xl leading-relaxed">
          לשיקום מוסדות ישראל על יסוד התורה — חידוש הסנהדרין בדורנו
        </p>
        <a href={`${base}articles`} class="inline-block mt-5 bg-white text-[#003f87] font-semibold px-6 py-2.5 rounded hover:bg-blue-50 transition-colors text-sm">
          רבנים ותומכים ◀
        </a>
      </div>
      <div class="shrink-0">
        <a href={`${base}articles`}>
          <img
            src={`${base}images/39adaf0c6f913e19ba81a7ad56d7af05.jpg`}
            alt="רבני הסנהדרין"
            class="w-72 h-auto rounded-lg shadow-lg border-2 border-blue-300 hover:opacity-90 transition-opacity"
          />
        </a>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 py-10 space-y-8">

    <!-- Opening paragraph -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <p class="text-gray-700 leading-relaxed text-base">
        כמעט אלפיים שנה חלפו מעת חורבן בית מקדשנו ויציאתנו לגלות הארוכה. התפזרנו בארבע קצוות תבל. כל קהילה העמידה בראשה חכם שנאלץ להתמודד עם גזירות מקומיות ועם חיים בצל תרבות שולטת מקומית. כך מהלכה פסוקה אחת בישראל — בבחינת הציווי החוזר "תּוֹרָה אַחַת וּמִשְׁפָּט אֶחָד יִהְיֶה לָכֶם"... נעשו לדאבוננו תורות הרבה!
      </p>
      <p class="text-gray-700 leading-relaxed mt-4">
        האחד מסתכל על השני בעין חשדנית ויש מתנשאים ויש מזלזלים... עתה מששבנו לארץ ישראל נוצרה מציאות קשה ובלתי אפשרית, חכמי התורה — זה מתיר בזה והשני אוסר ומחמיר.
      </p>
    </div>

    <!-- Tiberias & Renewal session photo -->
    <div class="grid md:grid-cols-2 gap-6">
      <div class="bg-white rounded-lg border border-[#dde3ed] overflow-hidden shadow-sm">
        <img
          src={`${base}images/13b5d640cee1b2a4fcb4e5c840e116cb.jpg`}
          alt="מעמד חידוש הסנהדרין בטבריה"
          class="w-full h-44 object-cover"
        />
        <div class="p-4">
          <p class="text-sm text-[#003f87] font-semibold">מעמד חידוש הסנהדרין בטבריה (תשס"ה)</p>
          <p class="text-xs text-gray-500 mt-1">שבעים ואחד סמוכים התכנסו והכריזו על חידוש הסנהדרין</p>
        </div>
      </div>
      <div class="bg-white rounded-lg border border-[#dde3ed] overflow-hidden shadow-sm">
        <img
          src={`${base}images/4d34dcb67b7bbeee6c93cd06c1b34a6c.jpg`}
          alt="טבריה — עיר חידוש הסנהדרין"
          class="w-full h-44 object-cover"
        />
        <div class="p-4">
          <p class="text-sm text-[#003f87] font-semibold">טבריה — עיר חידוש הסנהדרין</p>
          <p class="text-xs text-gray-500 mt-1">לפי המסורת, בטבריה תחודש הסנהדרין בדורות האחרונים</p>
        </div>
      </div>
    </div>

    <!-- Rabbi Meir Ba'al HaNes & Tiberias historical note -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <div class="flex items-start gap-3 mb-4">
        <div class="shrink-0 w-1 self-stretch bg-[#003f87] rounded-full"></div>
        <h2 class="text-xl font-bold text-[#003f87]">טבריה ורבי מאיר בעל הנס</h2>
      </div>
      <div class="space-y-3 text-gray-700 leading-relaxed text-sm">
        <p>
          רבי מאיר בעל הנס, ידוע כמי שניסה לחדש את הסנהדרין עקב כמיהתו לגאולה, שידע שתגיע לאחר חידוש הסנהדרין.
        </p>
        <p>
          הוא היה בין החכמים שייסדו מחדש את הסנהדרין באושא, לאחר שנעקרה ונסגרה ביבנה, לאחר חורבן בית המקדש השני, בעקבות מרד בר כוכבא בשנים ג'תתצ"ב–ג'תתצ"ו (132–136 למניינם) לספירה.
        </p>
        <p>
          בתלמוד הבבלי מתואר כי שם מונה להיות ה'חכם'. בתקופת מעבר הסנהדרין לאושא ישב רבי מאיר בעיירות טבעין וערדסקוס הסמוכות לחיפה.
        </p>
      </div>
    </div>

    <!-- Supporters preview -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <h2 class="text-xl font-bold text-[#003f87] mb-4">רבנים תומכים</h2>
      <ul class="space-y-2 text-gray-700">
        <li class="flex items-start gap-2">
          <span class="text-[#003f87] mt-1">◀</span>
          <a href={`${base}articles#maazuz`} class="hover:text-[#003f87] hover:underline">הרה"ג מאיר מאזוז זצ"ל</a>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#003f87] mt-1">◀</span>
          <a href={`${base}articles#sabato`} class="hover:text-[#003f87] hover:underline">הרה"ג שבתי הכהן סבתו שליט"א</a>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#003f87] mt-1">◀</span>
          <a href={`${base}articles#kook`} class="hover:text-[#003f87] hover:underline">הרה"ג הראי"ה קוק זצ"ל</a>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-[#003f87] mt-1">◀</span>
          <a href={`${base}articles#steinsaltz`} class="hover:text-[#003f87] hover:underline">הרה"ג עדין אבן ישראל שטיינזלץ זצ"ל</a>
        </li>
      </ul>
      <a href={`${base}articles`} class="inline-block mt-4 text-sm text-[#003f87] font-medium hover:underline">
        למאמרים נוספים ולרבנים נוספים התומכים ◀
      </a>
    </div>

    <!-- Halachic background -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <h2 class="text-xl font-bold text-[#003f87] mb-4">רקע הלכתי</h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        גדול הפוסקים שעסק בעניין הוא הרמב"ם. בספרו 'היד החזקה' הרמב"ם פוסק את חובת תהליך בניין עם ישראל בארצו, ומרחיב בחיוב הקמת הסנהדרין ותפקידיה עם שיבתנו לארצנו.
      </p>
      <blockquote class="border-r-4 border-[#003f87] pr-4 py-2 bg-[#f5f8ff] rounded text-gray-700 text-sm leading-relaxed my-4">
        <strong>הלכה א</strong> — שלש מצות נצטוו ישראל בשעת כניסתן לארץ: למנות להם מלך שנאמר "שום תשים עליך מלך", ולהכרית זרעו של עמלק, ולבנות בית הבחירה שנאמר "לשכנו תדרשו ובאת שמה".
        <footer class="mt-2 text-[#003f87] font-medium">משנה תורה לרמב"ם · הלכות מלכים ומלחמות · פרק ראשון</footer>
      </blockquote>
      <a href={`${base}relevance`} class="inline-block mt-2 text-sm text-[#003f87] font-medium hover:underline">להמשך הרקע ההלכתי ◀</a>
    </div>

    <!-- Historical background -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <h2 class="text-xl font-bold text-[#003f87] mb-4">רקע היסטורי</h2>
      <p class="text-gray-700 leading-relaxed mb-3">
        סַנְהֶדְרִין (סנהדרֵי גדולה / בית דין הגדול) היא בית דין של שבעים ואחד דיינים שהיווה ערכאה עליונה לפסיקת הלכה ומשפט בעם היהודי. הסנהדרין פעלה בעם ישראל עד שנת ד'קפ"ה (425 למניינם) לערך.
      </p>
      <p class="text-gray-700 leading-relaxed">
        בתלמוד הבבלי, פירט רבי יוחנן מהן התכונות הנדרשות מחברי הסנהדרין: "אין מושיבים בסנהדרין אלא בעלי חכמה, בעלי מראה, בעלי קומה, בעלי זקנה..."
      </p>
      <a href={`${base}sanhedrin`} class="inline-block mt-3 text-sm text-[#003f87] font-medium hover:underline">על הסנהדרין ומשמעה ◀</a>
    </div>

    <!-- Additional topics -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <h2 class="text-xl font-bold text-[#003f87] mb-5">נושאים נוספים באתר</h2>
      <div class="grid md:grid-cols-2 gap-3">
        {[
          { href: `${base}relevance`,     label: 'רלוונטיות להיום',                    desc: 'מדוע חידוש הסנהדרין דחוף בדורנו' },
          { href: `${base}smicha`,        label: 'חידוש הסמיכה',                        desc: 'כיצד הוחדשה הסמיכה על פי הרמב"ם' },
          { href: `${base}small-bet-din`, label: 'ב"ד סנהדרין קטנה בכל עיר',           desc: 'הקמת בתי דין מקומיים בכל קהילה' },
          { href: `${base}tzochek`,       label: 'צוחק מי שצוחק אחרון',                desc: 'הלקח ההיסטורי ממתנגדי שיבת ציון' },
          { href: `${base}parshiot`,      label: 'פרשות השבוע',                         desc: 'הסנהדרין בפרשיות התורה השבועיות' },
          { href: `${base}faq`,           label: 'שאלות נפוצות',                        desc: 'תשובות לשאלות הנפוצות ביותר' },
        ].map(item => (
          <a href={item.href} class="block p-4 rounded-lg border border-[#dde3ed] hover:border-[#003f87] hover:bg-[#f5f8ff] transition-colors group">
            <p class="font-semibold text-[#003f87] group-hover:underline text-sm">{item.label} ◀</p>
            <p class="text-gray-500 text-xs mt-0.5">{item.desc}</p>
          </a>
        ))}
      </div>
    </div>

  </div>
</Layout>
