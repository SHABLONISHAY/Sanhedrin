---
import Layout from '../layouts/Layout.astro';

const faqs: { q: string; a: string | string[] }[] = [
  {
    q: 'מדוע צריך סנהדרין בדורנו?',
    a: 'הסנהדרין הינו המפתח לשיקום תורת ישראל ועם ישראל. בהעדר סנהדרין נעשית התורה כתורות רבות עם מחלוקות ללא יכולת להכריע בהן. זהו הגורם העיקרי לפילוג בין שלומי אמוני ישראל. אם הסנהדרין תתקבל על ידי שלומי אמוני ישראל, יש להניח, ששלומי אמוני ישראל יבחרו בנקל להרכיב את הממשלה הבאה. עוד על הרלוונטיות בדורנו ניתן לקרוא בעמוד "רלוונטיות להיום" שבאתר.',
  },
  {
    q: 'האם הסנהדרין צריכים לדעת 70 שפות? ומהם הקריטריונים בכלל?',
    a: [
      'ברור שבסנהדרין צריך שיהיו גדולי תלמידי החכמים שבדור. גם רצוי שידעו שפות רבות. אך הדרישה הזו נמצאת אך ורק באגדות חז"ל. אם היה מי שידע 70 שפות היה זה ממש בגדר פלא. למעשה מה שחשוב הוא שבין חברי הסנהדרין יהיו דוברי שפות מגוונות כך שניתן יהיה להביא לסנהדרין סוגיות מגוונות גם כאשר מעורב בהן הצורך בידע של שפות.',
      'לפי ה\'כסף משנה\' בהלכות סנהדרין, אין צורך גם שחברי הסנהדרין יהיו כאלה השולטים בכל מכמני התורה. מה שכן נחוץ — מי שמכיר היטב את כל התורה אבל לא בהכרח שולט בה מידית. מספיק אדם אחד כזה בסנהדרין כדי להכשירה. לידו צריך שישב אדם אחד לפחות שיכול לשאול בכל התורה כולה. שאר החברים יכול שיהיו כאלה שלמדו כמה שנים בישיבה והם מסוגלים לפתוח ספרים ולפתח עיון בסוגיות.',
    ],
  },
  {
    q: 'מי אחראי למנות סנהדרין? מי מינה בעבר?',
    a: 'בעבר מינה את הסנהדרין ציבור יוצאי מצרים בפיקוח משה רבנו. מכאן ואילך מי שנפטר או חלה וכיו"ב ונגרע מן הסנהדרין — מינה הסנהדרין תלמיד חכם חשוב במקומו. דרך זו החזיקה מעמד עד לתקופה הרומית, באשר אז הרומיים רדפו את חברי הסנהדרין ואת הסמוכים והמיתום כדי למנוע מנהיגות רוחנית לעם ישראל. הנזק הרוחני מביטול הסנהדרין היה עצום.',
  },
  {
    q: 'מה התוקף של הסנהדרין בדורנו?',
    a: [
      'לפי הרמב"ם, ניתן לחדש את הסנהדרין על ידי חידוש הסמיכה בדרכים שונות, כמו הסכמת חכמי ישראל על אישיות אחת כסמוך, וממנו והלאה תתפשט הסמיכה הלאה.',
      'התוקף הפורמלי הוא כתוקף כל סנהדרין, שהרי הכלל הוא \'יפתח בדורו כשמואל בדורו\'. אולם, הציבור הרחב לא הטמיע עדיין את משמעות החידוש ואף גדולי תורה רבים מביעים הסתייגות, מה שמרתיע חלקים רבים בציבור מלאמץ את עובדת הקמת הסנהדרין מחדש.',
    ],
  },
  {
    q: 'אילו רבנים תומכים בעניין?',
    a: 'הרבנים הבולטים שתמכו וליוו את חידוש הסמיכה היו: הרב משה הלברשטאם זצ"ל (שהיה סמוך פותח) והרב ברנדסדורפר זצ"ל (שניהם דיינים בעדה החרדית). את מהלך איסוף הסכמת חכמי ישראל לחידוש הסמיכה ליווה הרב זלמן נחמיה גולדברג שליט"א שאף ניסח את מכתב הבקשה להתייחסות לכך. בראש מחדשי הסנהדרין עמד הרב עדין אבן ישראל שטיינזלץ זצ"ל, ובראש הסנהדרין כיום עומד הרב צבי עידאן שליט"א, מחבר כמה ספרים.',
  },
  {
    q: 'במה יעסקו הסנהדרין כיום?',
    a: [
      'יכנסו בי"ד של רבנים אשר יתכנסו שבועית וידונו בבעיות השעה ויפרסמו החלטות שיישמעו בשמים ובארץ.',
      'יפעלו לאחד את ההלכה בישראל לתורה אחת לכל העם — ללא הבדלים וללא תוספות של חומרות מקומיות.',
      'יוציאו החלטות חשובות בנושאים שרבנים הממונים ע"י הממסד מתחמקים ומנועים מלעסוק בהם. כגון: עונש מוות למחבלים, להט"ב, פונדקאות, מסיון, שינוי שיטת הממשל, יישוב הארץ, סוגיות שמיטה וגאולת ישראל בדורנו, ועוד.',
    ],
  },
  {
    q: 'כיצד אני יכול לסייע?',
    a: 'דרכי הסיוע מגוונים: השתתפות בשיחות דיונים והרצאות בהן תובע תמיכה בקיום המוסד וחשיבותו. אם הנך תלמיד חכם (לאו דווקא חכם הרזין) או בעל תעודת סמיכה לרבנות — הרי אתה מוזמן להצטרף. כמו כן ניתן לסייע בתרומות ובטיפול בנושאים שיש צורך ברכזים כדי לממשם ולקדמם.',
  },
  {
    q: 'מדוע חלקים בממסד הרבני מתנגדים?',
    a: [
      'הממסד הרבני, כמו בכל הדורות, הינו מעצם טבעו — מנסיון של דורות — שמרני בגישתו לחידושים, ולכן קשה להטמיע בו את חידוש הרעיון.',
      'הרבנים החשובים שייכים בדרך כלל לממסד רבני כלשהו וממנו פרנסתם. ממסד כזה ייתפס כמיותר אם הציבור יאמץ את הרעיון שיש סנהדרין. התפתחות הסנהדרין, גם שלא ברצונה, מאיימת על כל הממסדים הרבניים בביטולם, ולכן גם באבדן מקורות הפרנסה של הרבנים השייכים לממסדים אלו.',
      'התנגדות להקמת הסנהדרין נצפתה כבר לפני כמאה שנים, כשנעשה אז ניסיון לחדש את הסנהדרין. העוסק בכך ניבא שתהיה התנגדות. כמו כן, בעיה קשה נוספת היא שישנם אישי מפתח ביהדות דורנו שמעמדם קרוב למעמד הסנהדרין. הקמת הסנהדרין, גם אם יצטרפו אליה — ייפגם מעמדם, באשר הכרעותיהם ההלכתיות לא תמיד יתקבלו ואף יעברו בקורת.',
      'בעיית המעמד של גדולי הדור הייתה מוכרת כבר בימי חז"ל כפי שהדבר התבטא ביחסם של בני בתירא למינויו של הלל לנשיא. וכן כפי שמובא במסכת אבות דרבי נתן (נוסחא א, פרק י): "הוא היה אומר, כל מי שיאמר לי קודם שאכנס לגדולה זו הכנס, רוצה אני שארד עמו עד לחייו. עכשיו שנכנסתי, כל מי שיאמר לי רד הימנה, רוצה אני שאפיל עליו קומקומוס של חמין. שהגדולה קשה היא להעלותה. וכשם שקשה היא להעלותה, כך קשה להורידה."',
    ],
  },
  {
    q: 'האם זה לא תפקידו של המשיח למנות סנהדרין?',
    a: 'ההיפך. ממסכת עירובין אנו יודעים שאליהו הנביא יבוא לסנהדרין לפני התגלותו (כדי לקבל אישור להיותו הנביא אליהו) והוא הרי יקדם למשיח. כך גם כתב הרמב"ם בפתח פירושו למסכת סנהדרין.',
  },
];
---

<Layout title="שאלות נפוצות">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#003f87] mb-2">שאלות נפוצות</h1>
    <div class="w-16 h-1 bg-[#003f87] mb-8"></div>

    <div class="space-y-4">
      {faqs.map((faq) => (
        <div class="bg-white rounded-lg border border-[#dde3ed] shadow-sm overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none hover:bg-[#f8faff] transition-colors">
              <h2 class="text-base font-semibold text-[#003f87] leading-snug">{faq.q}</h2>
              <svg class="w-5 h-5 text-[#003f87] shrink-0 mr-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-700 leading-relaxed text-sm border-t border-[#dde3ed] pt-4 space-y-3">
              {Array.isArray(faq.a)
                ? faq.a.map((para: string) => <p>{para}</p>)
                : <p>{faq.a}</p>
              }
            </div>
          </details>
        </div>
      ))}
    </div>

    <div class="mt-8 bg-[#e8f0fb] rounded-lg border border-[#c5d5f0] p-6">
      <p class="text-[#003f87] font-medium">יש לך שאלה נוספת?</p>
      <p class="text-gray-700 text-sm mt-1">פנה אלינו בדואר אלקטרוני: <a href="mailto:sanhedrin.leisrael@gmail.com" class="text-[#003f87] hover:underline font-medium" dir="ltr">sanhedrin.leisrael@gmail.com</a></p>
    </div>
  </div>
</Layout>
