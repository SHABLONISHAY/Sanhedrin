---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    q: 'מדוע צריך סנהדרין בדורנו?',
    a: 'ברור שבסנהדרין צריך שיהיו גדולי תלמידי החכמים שבדור. גם רצוי שידעו שפות רבות. אך הדרישה הזו נמצאת אך ורק באגדות חז"ל. מה שחשוב הוא שבין חברי הסנהדרין יהיו דוברי שפות מגוונות כך שניתן יהיה להביא לסנהדרין סוגיות מגוונות.',
  },
  {
    q: 'האם הסנהדרין צריכים לדעת 70 שפות? ומהם הקריטריונים בכלל?',
    a: 'לפי ה\'כסף משנה\' בהלכות סנהדרין, אין צורך גם שחברי הסנהדרין יהיו כאלה השולטים בכל מכמני התורה. מה שכן נחוץ — מי שמכיר היטב את כל התורה. מספיק אדם אחד כזה בסנהדרין כדי להכשירה.',
  },
  {
    q: 'מי אחראי למנות סנהדרין? מי מינה בעבר?',
    a: 'בעבר מינה את הסנהדרין ציבור יוצאי מצרים בפיקוח משה רבנו. דרך זו החזיקה מעמד עד לתקופה הרומית, באשר אז הרומיים רדפו את חברי הסנהדרין ואת הסמוכים והמיתום כדי למנוע מנהיגות רוחנית לעם ישראל.',
  },
  {
    q: 'מה התוקף של הסנהדרין בדורנו?',
    a: 'לפי הרמב"ם, ניתן לחדש את הסנהדרין על ידי חידוש הסמיכה בדרכים שונות, כמו הסכמת חכמי ישראל על אישיות אחת כסמוך, וממנו והלאה תתפשט הסמיכה הלאה. התוקף הפורמלי הוא כתוקף כל סנהדרין, שהרי הכלל הוא \'יפתח בדורו כשמואל בדורו\'.',
  },
  {
    q: 'אילו רבנים תומכים בעניין?',
    a: 'מגוון רבנים שתמכו ותומכים בעניין חידוש הסנהדרין. הרבנים הבולטים שתמכו וליוו את חידוש הסמיכה היו: הרב משה הלברשטאם זצ"ל והרב ברנדסדורפר זצ"ל. בראש מחדשי הסנהדרין עומד כיום הרב צבי עידאן שליט"א.',
  },
  {
    q: 'במה יעסקו הסנהדרין כיום?',
    a: 'יכנסו ב"ד של רבנים אשר יתכנסו שבועית וידונו בבעיות השעה ויפרסמו החלטות. יפעלו לאחד את ההלכה בישראל לתורה אחת לכל העם — ללא הבדלים וללא תוספות של חומרות מקומיות. יוציאו החלטות חשובות בנושאים שרבנים הממונים ע"י הממסד מתחמקים מלעסוק בהם.',
  },
  {
    q: 'כיצד אני יכול לסייע?',
    a: 'דרכי הסיוע מגוונים: השתתפות בשיחות דיונים והרצאות, הצטרפות כתלמיד חכם (לאו דווקא חכם הרזין), תרומות, וטיפול בנושאים שיש צורך ברכזים. ניתן גם לפנות בדואר אלקטרוני: sanhedrin.leisrael@gmail.com',
  },
  {
    q: 'מדוע חלקים בממסד הרבני מתנגדים?',
    a: 'הממסד הרבני, כמו בכל הדורות, שמרני בגישתו לחידושים. הרבנים החשובים שייכים בדרך כלל לממסד רבני כלשהו ומממנו פרנסתם. התפתחות הסנהדרין מאיימת על כל הממסדים הרבניים בביטולם ובאבדן מקורות פרנסה.',
  },
  {
    q: 'האם זה לא תפקידו של המשיח למנות סנהדרין?',
    a: 'ההיפך. ממסכת עירובין אנו יודעים שאליהו הנביא יבוא לסנהדרין לפני התגלותו (כדי לקבל אישור להיותו הנביא אליהו) והוא הרי יקדם למשיח. כך גם כתב הרמב"ם בפתח פירושו למסכת סנהדרין.',
  },
];
---

<Layout title="שאלות נפוצות">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#003f87] mb-2">שאלות נפוצות</h1>
    <div class="w-16 h-1 bg-[#003f87] mb-8"></div>

    <div class="space-y-4">
      {faqs.map((faq, i) => (
        <div class="bg-white rounded-lg border border-[#dde3ed] shadow-sm overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-6 cursor-pointer list-none select-none hover:bg-[#f8faff] transition-colors">
              <h2 class="text-base font-semibold text-[#003f87] leading-snug">{faq.q}</h2>
              <svg class="w-5 h-5 text-[#003f87] shrink-0 mr-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-gray-700 leading-relaxed text-sm border-t border-[#dde3ed] pt-4">
              {faq.a}
            </div>
          </details>
        </div>
      ))}
    </div>

    <div class="mt-8 bg-[#e8f0fb] rounded-lg border border-[#c5d5f0] p-6">
      <p class="text-[#003f87] font-medium">יש לך שאלה נוספת?</p>
      <p class="text-gray-700 text-sm mt-1">פנה אלינו בדואר אלקטרוני: <a href="mailto:sanhedrin.leisrael@gmail.com" class="text-[#003f87] hover:underline font-medium" dir="ltr">sanhedrin.leisrael@gmail.com</a></p>
    </div>
  </div>
</Layout>
