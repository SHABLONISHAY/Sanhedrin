---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout
  title="צור קשר"
  description='צרו קשר עם מיזם סנהדרין לישראל — דוא"ל, טלפון, ווטסאפ, ורשימת תפוצה להצטרפות'
>
  <div class="max-w-3xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#003f87] mb-2">צור קשר</h1>
    <div class="w-16 h-1 bg-[#003f87] mb-8"></div>

    <!-- Contact info -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm mb-6">
      <p class="text-gray-700 mb-6 leading-relaxed">
        אם התחברת לחשיבות העניין וברצונך לסייע ככל יכולתך, להלן דרכי הסיוע:
      </p>

      <ul class="space-y-3 mb-6">
        {[
          'פעילות הפצה ברשת',
          'חיבור קהלים ורבנים',
          'השתתפות בימי עיון וכנסים',
          'רישום במאגר התומכים',
          'סיוע בתרומה לקידום העניין (ניתן לתת ממעשר כספים)',
        ].map(item => (
          <li class="flex items-start gap-3 text-gray-700">
            <span class="text-[#003f87] font-bold mt-0.5">◀</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <div class="grid md:grid-cols-2 gap-4 border-t border-[#dde3ed] pt-6">
        <div class="bg-[#f5f8ff] rounded-lg p-4">
          <p class="text-xs text-gray-500 mb-1 font-medium">דואר אלקטרוני</p>
          <a href="mailto:sanhedrin.leisrael@gmail.com" class="text-[#003f87] font-medium hover:underline text-sm" dir="ltr">
            sanhedrin.leisrael@gmail.com
          </a>
        </div>
        <div class="bg-[#f5f8ff] rounded-lg p-4">
          <p class="text-xs text-gray-500 mb-1 font-medium">טלפון</p>
          <a href="tel:0543987273" class="text-[#003f87] font-medium hover:underline text-sm" dir="ltr">
            054-398-7273
          </a>
        </div>
        <div class="bg-[#f5f8ff] rounded-lg p-4">
          <p class="text-xs text-gray-500 mb-1 font-medium">ביט</p>
          <p class="text-gray-700 text-sm" dir="ltr">0543987273</p>
        </div>
        <div class="bg-[#f5f8ff] rounded-lg p-4">
          <p class="text-xs text-gray-500 mb-1 font-medium">תרומה מאובטחת</p>
          <p class="text-gray-700 text-sm mb-1">בבנייה. ניתן לתרום דרך</p>
          <a href="https://www.bitpay.co.il/app/charge/0543987273" target="_blank" rel="noopener" class="text-[#003f87] font-medium hover:underline text-sm">ביט</a>
          <p class="text-gray-500 text-xs mt-1">ולציין: עבור פעילות הסנהדרין</p>
        </div>
      </div>
    </div>

    <!-- Social / CTA buttons -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-6 shadow-sm mb-6">
      <h2 class="text-lg font-semibold text-[#003f87] mb-4">עקבו אחרינו</h2>
      <div class="grid grid-cols-2 gap-3">

        <!-- WhatsApp קבוצה — Primary / featured -->
        <a
          href="https://chat.whatsapp.com/JO8eiPqh3eyCYtZ7GDt9Xg"
          target="_blank"
          rel="noopener"
          class="col-span-2 relative bg-[#25D366] text-white rounded-xl p-5 flex items-center gap-4 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
        >
          <span class="absolute top-3 left-3 bg-white text-[#25D366] text-xs font-bold px-2 py-0.5 rounded-full leading-none">מומלץ</span>
          <svg class="w-10 h-10 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          <div>
            <p class="font-bold text-base">הצטרף לקבוצת העדכונים</p>
            <p class="text-green-100 text-xs mt-0.5">דברי תורה בכל שישי + מאמרים חדשים</p>
          </div>
        </a>

        <!-- WhatsApp ישירה — Secondary -->
        <a
          href="https://wa.me/972543987273?text=%D7%A9%D7%9C%D7%95%D7%9D%2C%20%D7%94%D7%92%D7%A2%D7%AA%D7%99%20%D7%93%D7%A8%D7%9A%20%D7%94%D7%90%D7%AA%D7%A8%20%D7%A1%D7%A0%D7%94%D7%93%D7%A8%D7%99%D7%9F%20%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C"
          target="_blank"
          rel="noopener"
          class="bg-[#128C7E] text-white rounded-xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all text-sm font-medium"
        >
          <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          פנייה ישירה
        </a>

        <!-- Facebook -->
        <a
          href="https://m.facebook.com/sanhedrin.leisrael"
          target="_blank"
          rel="noopener"
          class="bg-[#1877F2] text-white rounded-xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all text-sm font-medium"
        >
          <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          פייסבוק
        </a>

        <!-- Messenger -->
        <a
          href="https://m.me/sanhedrin.leisrael"
          target="_blank"
          rel="noopener"
          class="bg-[#0084FF] text-white rounded-xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all text-sm font-medium"
        >
          <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 0C5.373 0 0 4.975 0 11.111c0 3.498 1.744 6.614 4.469 8.654V24l4.088-2.242c1.092.3 2.246.464 3.443.464 6.627 0 12-4.975 12-11.111C24 4.975 18.627 0 12 0zm1.191 14.963l-3.055-3.26-5.963 3.26L10.732 8l3.131 3.259L19.752 8l-6.561 6.963z"/>
          </svg>
          מסנג'ר
        </a>

        <!-- Email -->
        <a
          href="mailto:sanhedrin.leisrael@gmail.com?subject=%D7%A4%D7%A0%D7%99%D7%99%D7%94%20%D7%9E%D7%94%D7%90%D7%AA%D7%A8%20%D7%A1%D7%A0%D7%94%D7%93%D7%A8%D7%99%D7%9F%20%D7%9C%D7%99%D7%A9%D7%A8%D7%90%D7%9C"
          class="bg-[#EA4335] text-white rounded-xl p-4 flex items-center gap-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all text-sm font-medium"
        >
          <svg class="w-6 h-6 shrink-0" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
          דוא"ל
        </a>

        <!-- Share website -->
        <button
          id="share-btn"
          type="button"
          class="col-span-2 bg-[#f0f4ff] text-[#003f87] border border-[#c5d5f0] rounded-xl p-4 flex items-center justify-center gap-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all text-sm font-medium"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 12v8a2 2 0 002 2h12a2 2 0 002-2v-8M16 6l-4-4-4 4M12 2v13"/>
          </svg>
          <span id="share-label">שתף את האתר</span>
        </button>

      </div>
    </div>

    <script>
      document.getElementById('share-btn')?.addEventListener('click', async () => {
        const url = 'https://shablonishay.github.io/Sanhedrin/';
        const label = document.getElementById('share-label');
        try {
          if (navigator.share) {
            await navigator.share({ title: 'סנהדרין לישראל', url });
          } else {
            await navigator.clipboard.writeText(url);
            if (label) {
              label.textContent = 'הקישור הועתק! ✓';
              setTimeout(() => { label.textContent = 'שתף את האתר'; }, 2000);
            }
          }
        } catch (_) {}
      });
    </script>

    <!-- Contact form -->
    <div class="bg-white rounded-lg border border-[#dde3ed] p-8 shadow-sm">
      <h2 class="text-lg font-semibold text-[#003f87] mb-6">שלח הודעה</h2>
      <form class="space-y-5" method="post">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">שם מלא</label>
          <input
            type="text"
            id="name"
            name="name"
            class="w-full border border-[#dde3ed] rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-[#003f87] focus:ring-1 focus:ring-[#003f87]"
            placeholder="הכנס שם מלא"
          />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">דואר אלקטרוני</label>
          <input
            type="email"
            id="email"
            name="email"
            class="w-full border border-[#dde3ed] rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-[#003f87] focus:ring-1 focus:ring-[#003f87]"
            placeholder="example@mail.com"
            dir="ltr"
          />
        </div>
        <div>
          <label for="subject" class="block text-sm font-medium text-gray-700 mb-1">נושא (נא לפרט)</label>
          <select
            id="subject"
            name="subject"
            class="w-full border border-[#dde3ed] rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-[#003f87] focus:ring-1 focus:ring-[#003f87] bg-white"
          >
            <option value="">בחר נושא...</option>
            <option>פעילות הפצה ברשת</option>
            <option>חיבור קהלים ורבנים</option>
            <option>השתתפות בכנסים</option>
            <option>רישום במאגר התומכים</option>
            <option>תרומה</option>
            <option>אחר</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">הודעה</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            class="w-full border border-[#dde3ed] rounded-md px-4 py-2.5 text-sm focus:outline-none focus:border-[#003f87] focus:ring-1 focus:ring-[#003f87] resize-none"
            placeholder="כתוב את הודעתך כאן..."
          ></textarea>
        </div>
        <button
          type="submit"
          class="bg-[#003f87] text-white font-medium px-8 py-2.5 rounded-md hover:bg-[#0057b8] transition-colors text-sm"
        >
          שלח הודעה
        </button>
      </form>
    </div>
  </div>
</Layout>
