---

<Layout title="חשיבות הסנהדרין על סדר פרשות השבוע">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-[#003f87] mb-2">חשיבות הסנהדרין על סדר פרשות השבוע</h1>
    <div class="w-16 h-1 bg-[#003f87] mb-4"></div>

    <p class="text-gray-600 leading-relaxed mb-8">
      בכל פרשת שבוע ניתן למצוא רמז או לקח הנוגע לחידוש הסנהדרין ולמנהיגות תורנית אחת לעם ישראל. להלן דברי תורה עדכניים המחברים כל פרשה לנושא חידוש הסנהדרין בדורנו.
    </p>

    <div class="space-y-3">
      {entries.map((entry) => (
        <div class="bg-white rounded-lg border border-[#dde3ed] shadow-sm overflow-hidden">
          <details class="group">
            <summary class="flex items-center justify-between p-5 cursor-pointer list-none select-none hover:bg-[#f8faff] transition-colors">
              <div>
                <span class="text-xs font-semibold text-[#003f87] bg-[#e8f0fb] px-2 py-0.5 rounded ml-2">{entry.parasha}</span>
                <span class="text-sm font-semibold text-gray-800">{entry.title}</span>
              </div>
              <svg class="w-4 h-4 text-[#003f87] shrink-0 mr-2 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-5 pb-5 border-t border-[#dde3ed] pt-4 space-y-3">
              <p class="font-bold text-[#003f87] text-sm">{entry.title}</p>
              {entry.content.map((para: string) => (
                <p class="text-gray-700 leading-relaxed text-sm">{para}</p>
              ))}
              <p class="font-bold text-gray-800 text-sm">רק סנהדרין תאחד את ההלכה ואת העם!</p>
            </div>
          </details>
        </div>
      ))}
    </div>

    <div class="mt-8 bg-[#003f87] text-white rounded-lg p-8">
      <blockquote class="text-blue-100 leading-relaxed text-base italic mb-3">
        "הָשִׁיבָה שׁוֹפְטֵינוּ כְּבָרִאשׁוֹנָה, וְיוֹעֲצֵינוּ כְּבַתְּחִלָּה, וְתִמְלֹךְ עָלֵינוּ אַתָּה מְהֵרָה"
      </blockquote>
      <footer class="text-blue-300 text-sm font-medium">מתפילת שמונה עשרה</footer>
    </div>
  </div>
</Layout>
